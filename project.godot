[layer_names]

2d_render/layer_1="Players"
2d_render/layer_2="Objects"
2d_render/layer_3="Walls"
2d_render/layer_4="Staging"
2d_render/layer_5="Hazards"
2d_physics/layer_1="Players"
2d_navigation/layer_1="Players"
2d_physics/layer_2="Objects"
2d_navigation/layer_2="Objects"
2d_physics/layer_3="Walls"
2d_navigation/layer_3="Walls"
2d_physics/layer_4="Staging"
2d_navigation/layer_4="Staging"
2d_physics/layer_5="Hazards"
2d_navigation/layer_5="Hazards"
avoidance/layer_1="Players"
avoidance/layer_2="Ojbects"
avoidance/layer_3="Walls"
avoidance/layer_4="Stagins"
avoidance/layer_5="Hazards"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
