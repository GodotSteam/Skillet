; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[addons]

markdown_book/docs_folder="res://docs"

[application]

config/name="Skillet"
run/main_scene="res://src/scenes/game.tscn"
config/features=PackedStringArray("4.3", "GL Compatibility")
config/icon="res://icon.png"

[autoload]

Logging="*res://src/autoload/logging.gd"
Steamworks="*res://src/autoload/steamworks.gd"
SaveLoad="*res://src/autoload/save_load.gd"
Settings="*res://src/autoload/settings.gd"
Controllers="*res://src/autoload/controllers.gd"
Inventory="*res://src/autoload/inventory.gd"
Networking="*res://src/autoload/networking.gd"
Music="*res://src/autoload/music.tscn"
Loading="*res://src/autoload/loading.tscn"

[debug]

file_logging/enable_file_logging=true

[display]

window/size/viewport_width=2560
window/size/viewport_height=1440
window/stretch/mode="viewport"
window/stretch/aspect="ignore"

